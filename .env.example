# VybeKoderz AI Agent OS — Environment Variables

# Database (PostgreSQL — required for persistence, job queue, sessions)
DATABASE_URL=postgresql://user:password@localhost:5432/vybeos

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Auth (JWT)
JWT_SECRET=your-jwt-secret-change-in-production

# Auth (OAuth — register apps at Google Cloud Console + Azure Portal)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Voice (optional — simulated without keys)
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Browser Agent (optional — simulated without keys)
BROWSERBASE_API_KEY=your-browserbase-api-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id

# Artifact Storage (Railway Volume — persistent disk)
# Mount a Railway Volume to this path in your service settings
STORAGE_PATH=/data/artifacts

# App URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
PORT=3001
